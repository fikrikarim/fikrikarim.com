---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { title = "Fikri Karim", description, lang = "en" } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    {description && <meta name="description" content={description} />}
    {description && <meta property="og:description" content={description} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@fikrikarim" />
    <meta name="twitter:creator" content="@fikrikarim" />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <div class="flex justify-center">
      <div class="flex max-w-2xl flex-grow flex-col gap-14 px-8 py-14">
        <Header />
        <div>
          <slot />
        </div>
        <Footer />
      </div>
    </div>
  </body>
</html>
